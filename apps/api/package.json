{
  "name": "@bus/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run prisma:generate && nest build",
    "format": "concurrently \"prettier --write \\\"src/**/*.ts\\\" \\\"test/**/*.ts\\\"\" \"prisma format\"",
    "start": "pnpm run prisma:generate && nest start",
    "start:dev": "pnpm run prisma:generate && nest start --watch",
    "start:dev:awake": "caffeinate -i pnpm run start:dev",
    "start:debug": "pnpm run prisma:generate && nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "sync:routes:local": "curl --fail-with-body --request POST http://localhost:3000/api/admin/sync/routes",
    "sync:stops:local": "curl --fail-with-body --request POST http://localhost:3000/api/admin/sync/stops",
    "lint": "concurrently \"eslint \\\"{src,test}/**/*.ts\\\"\" \"prisma validate\"",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:migrate:create": "prisma migrate dev --create-only",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:diff": "prisma migrate diff --from-migrations prisma/migrations --to-schema prisma --script",
    "prisma:migrate:diff:empty": "prisma migrate diff --from-empty --to-schema prisma --script",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:validate": "prisma validate",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "pnpm run prisma:generate && NODE_OPTIONS=--experimental-vm-modules jest",
    "test:e2e": "pnpm run prisma:generate && NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-e2e.json",
    "test:e2e:db": "pnpm run prisma:generate && NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-db-e2e.json",
    "typecheck": "pnpm run prisma:generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bus/shared": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/nestjs-api-reference": "^1.1.19",
    "dotenv": "^17.4.2",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
