{
  "name": "bus",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "build": "react-router build",
    "dev": "pnpm run dev:proxy & pnpm run dev:app",
    "dev:app": "react-router dev",
    "dev:proxy": "wrangler dev --config workers/tdx-proxy/wrangler.jsonc --port 3000",
    "deploy:proxy": "wrangler deploy --config workers/tdx-proxy/wrangler.jsonc",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint ."
  },
  "dependencies": {
    "@mantine/core": "^8.2.1",
    "@mantine/hooks": "^8.2.1",
    "@react-router/node": "^7.14.0",
    "@react-router/serve": "^7.14.0",
    "@reduxjs/toolkit": "^2.8.2",
    "@remixicon/react": "^4.6.0",
    "@turf/boolean-point-in-polygon": "^7.3.1",
    "@turf/distance": "^7.3.4",
    "@turf/helpers": "^7.3.1",
    "@types/topojson-client": "^3.1.5",
    "i18next": "^25.10.2",
    "isbot": "^5.1.27",
    "maplibre-gl": "^5.6.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.6.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.14.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@eslint/json": "^0.13.0",
    "@react-router/dev": "^7.14.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^20",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/topojson-specification": "^1.0.5",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0"
  }
}
